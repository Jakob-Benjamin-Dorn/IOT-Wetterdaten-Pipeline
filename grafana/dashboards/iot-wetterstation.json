        {
            "id": 1,
            "type": "text",
            "title": "\u00dcbersicht",
            "gridPos": {
                "x": 0,
                "y": 0,
                "w": 24,
                "h": 5
            },
            "options": {
                "mode": "markdown",
                "content": "# IoT-Wetterstation\n\nKarlsruhe-Wetterdaten als Near-Realtime-Messungen vom ESP32-C6-Zero mit BME280-Sensor.\n\nGemessen werden Temperatur, Luftfeuchtigkeit und Luftdruck. Die Rohdaten werden lokal in LocalStack-S3 archiviert und validierte Messwerte in PostgreSQL gespeichert."
            }
        },
        {
            "id": 2,
            "type": "stat",
            "title": "Letzte Messwerte",
            "datasource": {
                "type": "postgres",
                "uid": "wetter-postgres"
            },
            "gridPos": {
                "x": 0,
                "y": 5,
                "w": 24,
                "h": 6
            },
            "targets": [
                {
                    "refId": "A",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  temperature_c AS \"Temperatur \u00b0C\",\n  humidity_pct AS \"Luftfeuchtigkeit %\",\n  pressure_hpa AS \"Luftdruck hPa\"\nFROM weather_readings\nORDER BY received_at DESC\nLIMIT 1;",
                    "datasource": {
                        "type": "postgres",
                        "uid": "wetter-postgres"
                    }
                }
            ],
            "options": {
                "reduceOptions": {
                    "values": false,
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": ""
                },
                "orientation": "auto",
                "textMode": "value_and_name",
                "colorMode": "value",
                "graphMode": "area",
                "justifyMode": "auto"
            },
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            }
        },
        {
            "id": 6,
            "type": "table",
            "title": "Letzte Aktualisierung",
            "datasource": {
                "type": "postgres",
                "uid": "wetter-postgres"
            },
            "gridPos": {
                "x": 0,
                "y": 11,
                "w": 24,
                "h": 4
            },
            "targets": [
                {
                    "refId": "A",
                    "format": "table",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  source AS \"Quelle\",\n  device_id AS \"Ger\u00e4t / Referenz\",\n  received_at AS \"Zeitpunkt\"\nFROM weather_readings\nORDER BY received_at DESC\nLIMIT 1;",
                    "datasource": {
                        "type": "postgres",
                        "uid": "wetter-postgres"
                    }
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "align": "auto",
                        "cellOptions": {
                            "type": "auto"
                        },
                        "inspect": false
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "showHeader": true,
                "cellHeight": "sm"
            }
        },
        {
            "id": 3,
            "type": "timeseries",
            "title": "Temperaturverlauf",
            "datasource": {
                "type": "postgres",
                "uid": "wetter-postgres"
            },
            "gridPos": {
                "x": 0,
                "y": 15,
                "w": 8,
                "h": 8
            },
            "targets": [
                {
                    "refId": "A",
                    "format": "time_series",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  received_at AS \"time\",\n  temperature_c AS \"Sensor\"\nFROM weather_readings\nWHERE\n  $__timeFilter(received_at)\n  AND source = 'sensor'\nORDER BY received_at;",
                    "datasource": {
                        "type": "postgres",
                        "uid": "wetter-postgres"
                    }
                },
                {
                    "refId": "B",
                    "format": "time_series",
                    "rawQuery": true,
                    "rawSql": "SELECT\n  received_at AS \"time\",\n  temperature_c AS \"OpenWeather\"\nFROM weather_readings\nWHERE\n  $__timeFilter(received_at)\n  AND source = 'openweather'\nORDER BY received_at;",
                    "datasource": {
                        "type": "postgres",
                        "uid": "wetter-postgres"
                    }
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "celsius",
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "lineWidth": 1,
                        "fillOpacity": 0,
                        "gradientMode": "none",
                        "showPoints": "auto",
                        "pointSize": 5,
                        "spanNulls": false,
                        "insertNulls": 3600000,
                        "axisPlacement": "auto",
                        "scaleDistribution": {
                            "type": "linear"
                        },
                        "hideFrom": {
                            "tooltip": false,
                            "viz": false,
                            "legend": false
                        },
                        "thresholdsStyle": {
                            "mode": "off"
                        }
                    }
                },
                "overrides": [
